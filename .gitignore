# =============================================================================
# .gitignore — Reglas de exclusión para el repositorio fullstack-dashboard
# =============================================================================

# -----------------------------------------------------------------------------
# Dependencias y artefactos de compilación
# -----------------------------------------------------------------------------
node_modules/
dist/
coverage/

# -----------------------------------------------------------------------------
# Archivos de configuración local y secretos
# -----------------------------------------------------------------------------
.env

# -----------------------------------------------------------------------------
# Archivos de log
# -----------------------------------------------------------------------------
*.log

# -----------------------------------------------------------------------------
# Archivos del sistema operativo (macOS / Windows)
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
