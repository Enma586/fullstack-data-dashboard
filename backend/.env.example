# =============================================================================
# .env.example — Variables de entorno para el backend del dashboard Olist
#
# Copiar a .env y ajustar los valores según el entorno local.
# =============================================================================

# -----------------------------------------------------------------------------
# Base de datos — Cadena de conexión a PostgreSQL (Data Warehouse Olist)
# Formato: postgresql://USUARIO:CONTRASEÑA@HOST:PUERTO/BASE_DATOS?schema=raw
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://olist:olist123@localhost:5432/olist_dw?schema=raw

# -----------------------------------------------------------------------------
# Servidor — Puerto y modo de ejecución de Express
# -----------------------------------------------------------------------------
PORT=3000
NODE_ENV=development
